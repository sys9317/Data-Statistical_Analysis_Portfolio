# Part 4
nber <- nber |>
filter(hufinal < 213)
nrow(nber)
nrow(cps2021)
# Part 5
nber_cps <- bind_cols(cps2021,nber)
# Part 6
nber <- nber |>
mutate(dividedpwc = pwcmpwgt/10000)
# Part 7
nber_cps_svy <- nber_cps |>
filter(!is.na(pwcmpwgt)) |>
as_survey_design(weight = pwcmpwgt)
# Part 8
nber_cps_svy <- nber_cps_svy |>
mutate(
EMPSTATUS = as.numeric(EMPSTAT),
labor_force_nber = if_else(LABFORCE == 2, true = 1, false = 0),
employed_nber  = if_else(EMPSTAT %in% c(10, 12), true = 1, false =0),
unemployed_nber  = if_else(EMPSTAT %in% c(21, 22), true = 1,false = 0)
)
# Part 9
nber_cps_svy <- nber_cps_svy |>
group_by(YEAR) |>
filter(AGE == 16, POPSTAT == 1) |>
summarise(
total_labor_nber = survey_total(labor_force_nber),
total_employed_nber = survey_total(employed_nber),
total_unemployed_nber = survey_total(unemployed_nber)
)
cps_svy |>
filter(RACE %in% c(100,200,650),
EMPSTAT %in% c(10,12)) |>
ggplot() +
geom_bar(mapping = aes (x = AGE), color = "blue", alpha = 0.6) +
labs(
title = "Distribution of Age",
subtitle = "for employed Black, White and Asian population",
caption = "Data provided by IPUMS CPS"
) +
ylab("Number of population")
