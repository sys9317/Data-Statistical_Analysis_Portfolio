)
# Random forest
library(ranger)
rf_Chicago <- rand_forest(
mtry = tune(),
min_n = tune(),
trees = 300
) |>
set_mode("regression") |>
set_engine("ranger",
importance = "impurity")
rf_wf <- workflow() |>
add_model(rf_Chicago) |>
add_recipe(Chicago_rec)
rf_grid <- grid_regular(
mtry(range = c(1, 5)),
min_n(range = c(1, 5)),
levels = 3
)
rf_resample <- tune_grid(
rf_wf,
resamples = Chicago_folds,
grid = rf_grid,
metrics = metric_set(rmse)
)
